# Neon Postgres connection string (from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.aws-ap-southeast-1.aws.neon.tech/talkpc?sslmode=require

# JWT signing — generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# Access token expiry (minutes). Default 24h.
JWT_EXPIRES_MIN=1440

# License policy
DEVICES_PER_USER=1
